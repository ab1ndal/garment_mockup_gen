# Bindal's Creation — Mockup Generator
# Copy to .env and fill in the secrets. .env is gitignored; never commit it.

# --- Google AI / Gemini ---
GOOGLE_API_KEY=your-google-genai-or-ai-studio-key    # required (secret)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-pro
BATCH_MODEL_CONCURRENCY=gemini-3.1-flash-image=3,gemini-3-pro-image=3   # per-model batch drainers

# --- Vertex AI (Cloud billing instead of AI Studio) ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=bindalscreation
GOOGLE_CLOUD_LOCATION=global
GOOGLE_VERTEX_SA_JSON=                                # secret; path or JSON. Falls back to GOOGLE_DRIVE_SA_JSON

# --- Google Drive (image-preview endpoint) ---
GOOGLE_DRIVE_SA_JSON=                                 # secret; path or JSON key

# --- OpenAI (legacy gpt-image-1 path only) ---
OPENAI_API_KEY=your-openai-api-key                    # required (secret); set "unused" if never invoked

# --- Backend CORS ---
# Comma-separated frontend origins allowed to call the API. Set the deployed
# frontend URL here or browser requests are blocked.
FRONTEND_ORIGINS=http://localhost:5173

# --- Supabase ---
SUPABASE_PROJECT_ID=epotsxdugwfhyeiudjox
SUPABASE_PUBLISHABLE_KEY=sb_publishable_KaCtdfEnbgOpHsKjDDIO6Q_rp0UMgd5
SUPABASE_SECRET_KEY=your-service-secret-key           # secret; server-only, never ship to frontend

# --- VEO video generation ---
# Vertex uses -001 IDs, not AI Studio's -preview. Region is fixed internally to us-central1.
VEO_MODEL=veo-3.1-generate-001
VEO_POLL_TIMEOUT_SEC=900
VEO_POLL_INTERVAL_SEC=10

# --- Frontend (frontend/.env, NOT this file) ---
#   VITE_SUPABASE_URL=https://<project-ref>.supabase.co
#   VITE_SUPABASE_ANON_KEY=<same as SUPABASE_PUBLISHABLE_KEY>
#   VITE_API_URL=http://localhost:8000
