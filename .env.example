# =============================================================================
# Bindal's Creation — Mockup Generator — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# Never commit .env — it is gitignored.
# Keys marked (required) will raise at runtime when first accessed.
# Keys marked (default: X) are optional; the shown default is used if unset.
# =============================================================================


# --- Google AI / Gemini (required) ---
# AI Studio key for Gemini Developer API (used when GOOGLE_GENAI_USE_VERTEXAI is off).
# When Vertex is enabled this key is still required as a fallback; it can be a
# dummy value if your SA has the aiplatform.user role.
GOOGLE_API_KEY=your-google-genai-or-ai-studio-key   # required

# Gemini image-generation model name (default: gemini-3-pro-image)
# Override to target a preview or flash variant.
GEMINI_IMAGE_MODEL=gemini-3-pro-image                # default: gemini-3-pro-image

# Advanced Gemini text model for prompt refinement (default: gemini-2.5-pro)
GEMINI_TEXT_MODEL=gemini-2.5-pro          # advanced text model for prompt refinement


# --- Vertex AI billing (required when routing through Vertex) ---
# Set to "true" to route Gemini calls through Vertex AI (Cloud pay-as-you-go)
# instead of the Gemini Developer API (AI Studio prepay credits).
GOOGLE_GENAI_USE_VERTEXAI=                           # default: "" (off); set to "true" to route via Vertex

# GCP project id. Required when GOOGLE_GENAI_USE_VERTEXAI=true.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id             # required (Vertex)

# Vertex AI / Cloud region (default: global)
GOOGLE_CLOUD_LOCATION=global                         # default: global

# Service-account credentials for Vertex AI — path to a JSON key file OR the
# raw JSON content. On headless deploys (HF Spaces) paste the JSON content as a
# secret. Falls back to GOOGLE_DRIVE_SA_JSON if unset, so a single SA with
# roles/aiplatform.user + Drive reader can serve both.
GOOGLE_VERTEX_SA_JSON=                               # optional (falls back to GOOGLE_DRIVE_SA_JSON)


# --- Google Drive (optional — needed for Drive image-preview endpoint) ---
# Service-account credentials for Drive read access.
# Value: either a path to a JSON key file (e.g. ./sa-drive.json) or the raw
# JSON content as a single line. The SA must be shared on each product folder.
GOOGLE_DRIVE_SA_JSON=                                # optional


# --- OpenAI (required — legacy gpt-image-1 path only) ---
# Only used by mockup_generator/create_mockup.py (the old OpenAI engine).
# If you never invoke that code path, set a dummy value: OPENAI_API_KEY=unused
OPENAI_API_KEY=your-openai-api-key                   # required


# --- Supabase (shared with the Inventory-Management project) ---
SUPABASE_PROJECT_ID=your-project-ref                 # optional (required for DB features)
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key   # optional (client-safe)
SUPABASE_SECRET_KEY=your-service-secret-key          # optional; server-only — never ship to the client/frontend


# --- VEO video generation ---
# Model name (default: veo-3.1-generate-preview)
VEO_MODEL=veo-3.1-generate-preview                   # default: veo-3.1-generate-preview

# Maximum seconds to wait for a VEO async job (default: 900 = 15 min)
# VEO is slow (several minutes per clip); raise on deploys with long timeouts.
VEO_POLL_TIMEOUT_SEC=900                             # default: 900

# Seconds between VEO operation status polls (default: 10)
VEO_POLL_INTERVAL_SEC=10                             # default: 10


# --- Frontend Vite env vars (frontend/.env, NOT this file) ---
# These are consumed by the Vite / React frontend, not the Python backend.
# Put them in frontend/.env (or Vercel env vars on deploy):
#
#   VITE_SUPABASE_URL=https://<project-ref>.supabase.co
#   VITE_SUPABASE_ANON_KEY=<same as SUPABASE_PUBLISHABLE_KEY>
#   VITE_API_URL=http://localhost:8000       # local backend
